---
export const prerender = true;
const target = "/em/";

export function GET() {
  return new Response(null, {
    status: 301,
    headers: { Location: target },
  });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <title>Redirecting to /em</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>/em</a>…</p>
  </body>
</html>
